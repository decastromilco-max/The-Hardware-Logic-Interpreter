import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.Statement;
import java.util.ArrayList;
import java.util.List;

public class HardwareRepository {

    private String dbURL = "jdbc:sqlite:HardwareSpecs.db";
    private List<Hardware> hardwareData;

    public HardwareRepository() {
        hardwareData = new ArrayList<>();
        try {

            Class.forName("org.sqlite.JDBC");
            System.out.println("Driver loaded successfully!");
        } catch (ClassNotFoundException e) {
            System.err.println("JDBC Driver not found!");
        }
    }

    public List<Hardware> getAllHardware() {
        hardwareData.clear();

        String query = "SELECT * FROM tbl_hardware";

        try (Connection conn = DriverManager.getConnection(dbURL);
             Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(query)) {

            while (rs.next()) {

                int id = rs.getInt("productId");
                String brand = rs.getString("brand");
                int spec = rs.getInt("spec");
                String type = rs.getString("type");


                if ("Laptop".equalsIgnoreCase(type)) {
                    hardwareData.add(new Laptop.LaptopBuilder()
                            .setId(id)
                            .setBrand(brand)
                            .setSpec(spec)
                            .build());
                } else if ("Phone".equalsIgnoreCase(type)) {
                    hardwareData.add(new Phone.PhoneBuilder()
                            .setId(id)
                            .setBrand(brand)
                            .setSpec(spec)
                            .build());
                }
            }
        } catch (Exception e) {
            System.err.println("Database Connection Error: " + e.getMessage());
        }
        return hardwareData;
    }
}